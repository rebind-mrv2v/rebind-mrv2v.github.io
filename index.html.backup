              <div class="column is-6">
                <p class="has-text-centered" style="font-weight: bold; margin-bottom: 15px; font-size: 1.1em;">Ours (ReBind)</p>
                <video autoplay loop muted playsinline style="width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
                  <source src="static/videos/rv2v_ours.mp4" type="video/mp4">
                </video>
              </div>
            </div>
          </div>
        </div>

        <!-- MRV2V Comparison (Right Half) -->
        <div class="column is-half">
          <div style="background: #f5f5f5; padding: 30px; border-radius: 10px; height: 100%;">
            <h4 class="title is-5 has-text-centered" style="margin-bottom: 30px;">MRV2V</h4>

            <!-- Source and References -->
            <div class="columns is-centered" style="margin-bottom: 30px;">
              <div class="column is-5">
                <p class="has-text-centered" style="font-weight: bold; margin-bottom: 15px; font-size: 1.1em;">Source Video</p>
                <video autoplay loop muted playsinline style="width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
                  <source src="static/videos/mrv2v_source.mp4" type="video/mp4">
                </video>
              </div>
              <div class="column is-3">
                <p class="has-text-centered" style="font-weight: bold; margin-bottom: 15px; font-size: 1.1em;">Ref 1</p>
                <img src="static/images/mrv2v_ref1.png" alt="Reference 1" style="width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
              </div>
              <div class="column is-3">
                <p class="has-text-centered" style="font-weight: bold; margin-bottom: 15px; font-size: 1.1em;">Ref 2</p>
                <img src="static/images/mrv2v_ref2.jpg" alt="Reference 2" style="width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
              </div>
            </div>

            <!-- Methods -->
            <div class="columns is-multiline">
              <div class="column is-6">
                <p class="has-text-centered" style="font-weight: bold; margin-bottom: 15px; font-size: 1.1em;">UniVideo</p>
                <video autoplay loop muted playsinline style="width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
                  <source src="static/videos/mrv2v_univideo.mp4" type="video/mp4">
                </video>
              </div>
              <div class="column is-6">
                <p class="has-text-centered" style="font-weight: bold; margin-bottom: 15px; font-size: 1.1em;">Kiwi-Edit</p>
                <video autoplay loop muted playsinline style="width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
                  <source src="static/videos/mrv2v_kiwi.mp4" type="video/mp4">
                </video>
              </div>
              <div class="column is-6">
                <p class="has-text-centered" style="font-weight: bold; margin-bottom: 15px; font-size: 1.1em;">OmniWeaving</p>
                <video autoplay loop muted playsinline style="width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
                  <source src="static/videos/mrv2v_omniweaving.mp4" type="video/mp4">
                </video>
              </div>
              <div class="column is-6">
                <p class="has-text-centered" style="font-weight: bold; margin-bottom: 15px; font-size: 1.1em;">Ours (ReBind)</p>
                <video autoplay loop muted playsinline style="width: 100%; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,0.15);">
                  <source src="static/videos/mrv2v_ours.mp4" type="video/mp4">
                </video>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Summary Text -->
      <div class="columns is-centered" style="margin-top: 30px;">
        <div class="column is-four-fifths">
          <p class="has-text-justified has-text-centered">
            <b>ReBind</b> achieves state-of-the-art performance among open-source methods on both single-reference (RV2V) and
            multi-reference (MRV2V) video editing benchmarks, with particularly strong performance on multi-reference scenarios
            that require precise coordination across visual sources.
          </p>
        </div>
